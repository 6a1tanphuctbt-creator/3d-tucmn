<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>3D Scan - Trung Ương Cục Miền Nam</title>

<style>
body{
    margin:0;
    overflow:hidden;
    background:#111;
    font-family:Segoe UI, sans-serif;
}
#ui{
    position:absolute;
    top:20px;
    left:20px;
    color:white;
    background:rgba(0,0,0,0.6);
    padding:15px 20px;
    border-radius:12px;
    backdrop-filter:blur(4px);
    border:1px solid rgba(255,255,255,0.1);
}
h1{
    margin:0 0 5px 0;
    font-size:18px;
    color:#d4af37;
}
p{
    margin:0;
    font-size:13px;
    opacity:0.8;
}
</style>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
  }
}
</script>
</head>

<body>

<div id="ui">
    <h1>Trung Ương Cục Miền Nam</h1>
    <p>Kéo chuột để xoay • Cuộn để zoom</p>
</div>

<script type="module">

import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";

init();

function init(){

// ===== SCENE =====
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x1a1a1a);
scene.fog = new THREE.FogExp2(0x1a1a1a,0.015);

// ===== CAMERA =====
const camera = new THREE.PerspectiveCamera(
50,
window.innerWidth/window.innerHeight,
0.1,
1000
);
camera.position.set(20,15,25);

// ===== RENDERER =====
const renderer = new THREE.WebGLRenderer({antialias:true});
renderer.setSize(window.innerWidth,window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.5;
document.body.appendChild(renderer.domElement);

// ===== CONTROLS =====
const controls = new OrbitControls(camera,renderer.domElement);
controls.enableDamping = true;
controls.maxPolarAngle = Math.PI/2 - 0.05;

// ===== LIGHTING =====
const hemi = new THREE.HemisphereLight(0xffffff,0x222222,1.2);
scene.add(hemi);

const sun = new THREE.DirectionalLight(0xfff5d1,3);
sun.position.set(20,30,10);
sun.castShadow = true;
sun.shadow.mapSize.set(2048,2048);
scene.add(sun);

const rim = new THREE.DirectionalLight(0x88aaff,1);
rim.position.set(-20,10,-20);
scene.add(rim);

// ===== TERRAIN =====
const size = 80;
const geo = new THREE.PlaneGeometry(size,size,200,200);
const pos = geo.attributes.position;

for(let i=0;i<pos.count;i++){
    const x = pos.getX(i);
    const y = pos.getY(i);

    const height =
        Math.sin(x*0.2)*0.5 +
        Math.cos(y*0.2)*0.5 +
        Math.random()*0.2;

    pos.setZ(i,height);
}

geo.computeVertexNormals();

const mat = new THREE.MeshStandardMaterial({
    color:0x3a2f23,
    roughness:1
});

const terrain = new THREE.Mesh(geo,mat);
terrain.rotation.x = -Math.PI/2;
terrain.receiveShadow = true;
scene.add(terrain);

// ===== TRENCH =====
function createTrench(points){

    const shape = new THREE.Shape();
    shape.moveTo(-1,0);
    shape.lineTo(-0.7,-1.5);
    shape.lineTo(0.7,-1.5);
    shape.lineTo(1,0);

    const path = new THREE.CatmullRomCurve3(points);

    const geo = new THREE.ExtrudeGeometry(shape,{
        steps:200,
        bevelEnabled:false,
        extrudePath:path
    });

    const mat = new THREE.MeshStandardMaterial({color:0x20160f});
    const mesh = new THREE.Mesh(geo,mat);
    mesh.castShadow = true;
    mesh.receiveShadow = true;

    scene.add(mesh);
}

createTrench([
    new THREE.Vector3(-20,0.1,10),
    new THREE.Vector3(0,0.1,15),
    new THREE.Vector3(20,0.1,10)
]);

// ===== HOUSE =====
function createHouse(x,z){

    const group = new THREE.Group();

    const wood = new THREE.MeshStandardMaterial({
        color:0x4b2e1a,
        roughness:0.9
    });

    for(let i=-1;i<=1;i+=2){
        for(let j=-1;j<=1;j+=2){
            const col = new THREE.Mesh(
                new THREE.CylinderGeometry(0.12,0.15,4,16),
                wood
            );
            col.position.set(i*3,2,j*2);
            col.castShadow = true;
            group.add(col);
        }
    }

    const roof = new THREE.Mesh(
        new THREE.ConeGeometry(5,3,4),
        new THREE.MeshStandardMaterial({
            color:0x5a3e2b,
            roughness:1,
            flatShading:true
        })
    );

    roof.position.y = 5;
    roof.rotation.y = Math.PI/4;
    roof.castShadow = true;

    group.add(roof);

    group.position.set(x,0,z);
    scene.add(group);
}

createHouse(0,0);

// ===== VEGETATION =====
function addTree(x,z){

    const height = 10 + Math.random()*5;

    const trunk = new THREE.Mesh(
        new THREE.CylinderGeometry(0.2,0.3,height,12),
        new THREE.MeshStandardMaterial({color:0x3d2b1f})
    );

    trunk.position.set(x,height/2,z);
    trunk.castShadow = true;
    scene.add(trunk);

    const leaves = new THREE.Mesh(
        new THREE.SphereGeometry(2+Math.random(),16,16),
        new THREE.MeshStandardMaterial({
            color:0x1f3a1f,
            flatShading:true
        })
    );

    leaves.position.set(x,height+1,z);
    leaves.castShadow = true;
    scene.add(leaves);
}

for(let i=0;i<70;i++){
    const rx = (Math.random()-0.5)*70;
    const rz = (Math.random()-0.5)*70;

    if(Math.sqrt(rx*rx+rz*rz) > 8){
        addTree(rx,rz);
    }
}

// ===== ANIMATION =====
function animate(){
    requestAnimationFrame(animate);
    controls.update();
    renderer.render(scene,camera);
}
animate();

// ===== RESIZE =====
window.addEventListener("resize",()=>{
    camera.aspect = window.innerWidth/window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth,window.innerHeight);
});

}

</script>

</body>
</html>
